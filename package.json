{
  "name": "imessage-mcp",
  "version": "1.2.0",
  "description": "iMessage MCP server — 25 tools for searching, analyzing, and exploring your entire iMessage history on macOS",
  "author": "Ani Potts",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "imessage-mcp": "bin/imessage-mcp.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "server.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "doctor": "tsx src/commands/doctor.ts",
    "dump": "tsx src/commands/dump.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "better-sqlite3": "^12.6.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "imessage",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "modelcontextprotocol",
    "macos",
    "messages",
    "claude",
    "ai",
    "llm",
    "apple",
    "sms",
    "chat-history",
    "analytics"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anipotts/imessage-mcp.git"
  },
  "homepage": "https://github.com/anipotts/imessage-mcp",
  "bugs": {
    "url": "https://github.com/anipotts/imessage-mcp/issues"
  }
}
